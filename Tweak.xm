        NSData *data = [[NSData alloc] initWithBase64EncodedString:b64 options:0];
        NSString *html = [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];

        [self.webView loadHTMLString:html baseURL:nil];
