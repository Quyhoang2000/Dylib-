#import <UIKit/UIKit.h>
#import <WebKit/WebKit.h>

@interface QuyHoangWindow : UIWindow
@property (nonatomic, strong) WKWebView *webView;
@property (nonatomic, strong) UIButton *btnMenu;
@end

